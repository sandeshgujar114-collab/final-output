<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <SurfaceView
        android:id="@+id/surface_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <!-- Subtitle overlay -->
    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="80dp"
        android:layout_marginLeft="48dp"
        android:layout_marginRight="48dp"
        android:background="@color/subtitle_bg"
        android:gravity="center"
        android:padding="8dp"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:visibility="gone" />

    <!-- Controls overlay -->
    <RelativeLayout
        android:id="@+id/controls_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:visibility="gone">

        <!-- Top info bar -->
        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:background="#AA000000"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_white"
                android:textSize="22sp"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_boost_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔊 BOOST: OFF"
                android:textColor="@color/boost_off"
                android:textSize="16sp"
                android:layout_marginLeft="16dp" />

        </LinearLayout>

        <!-- Center play/pause indicator -->
        <TextView
            android:id="@+id/tv_play_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="▶"
            android:textSize="64sp"
            android:textColor="@color/accent" />

        <!-- Bottom controls -->
        <LinearLayout
            android:id="@+id/bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="#AA000000"
            android:orientation="vertical"
            android:padding="16dp">

            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:focusable="false"
                android:max="1000"
                android:progressDrawable="@drawable/seekbar_style"
                android:thumb="@drawable/seekbar_thumb" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tv_current_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@color/accent"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textColor="@color/text_gray"
                    android:textSize="14sp"
                    android:text="◀ ▶ Seek  |  ▲ Subs  |  ▼ Audio  |  ● Play/Pause" />

                <TextView
                    android:id="@+id/tv_total_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@color/text_gray"
                    android:textSize="18sp" />
            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

    <!-- Subtitle selection popup -->
    <LinearLayout
        android:id="@+id/subtitle_popup"
        android:layout_width="360dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/popup_bg"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📝 Subtitle Options"
            android:textColor="@color/accent"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <ListView
            android:id="@+id/list_subtitles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@android:color/transparent"
            android:dividerHeight="4dp" />
    </LinearLayout>

    <!-- Audio track popup -->
    <LinearLayout
        android:id="@+id/audio_popup"
        android:layout_width="360dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/popup_bg"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔊 Audio Options"
            android:textColor="@color/accent"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btn_toggle_boost"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🔊 Audio Boost: OFF"
            android:textSize="20sp"
            android:textColor="@color/text_white"
            android:background="@drawable/btn_selector"
            android:focusable="true"
            android:layout_marginBottom="8dp" />

        <ListView
            android:id="@+id/list_audio_tracks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@android:color/transparent"
            android:dividerHeight="4dp" />
    </LinearLayout>

</FrameLayout>
