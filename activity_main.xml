<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="48dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎬 TV Video Player"
        android:textColor="@color/accent"
        android:textSize="42sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lightweight Media Player for Android TV"
        android:textColor="@color/text_gray"
        android:textSize="20sp"
        android:layout_marginBottom="48dp" />

    <Button
        android:id="@+id/btn_browse_storage"
        android:layout_width="400dp"
        android:layout_height="72dp"
        android:text="📂  Browse Storage"
        android:textSize="24sp"
        android:textColor="@color/text_white"
        android:background="@drawable/btn_selector"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_browse_usb"
        android:layout_width="400dp"
        android:layout_height="72dp"
        android:text="🔌  Browse USB"
        android:textSize="24sp"
        android:textColor="@color/text_white"
        android:background="@drawable/btn_selector"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_resume"
        android:layout_width="400dp"
        android:layout_height="72dp"
        android:text="▶  Resume Last Video"
        android:textSize="24sp"
        android:textColor="@color/text_white"
        android:background="@drawable/btn_selector"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:visibility="gone" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Use DPAD to navigate • CENTER to select"
        android:textColor="@color/text_gray"
        android:textSize="16sp"
        android:layout_marginTop="32dp" />

</LinearLayout>
